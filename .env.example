# V25.1.0 Phase 1 shadow database
DATABASE_ENABLED=false
DATABASE_SHADOW_MODE=true
DATABASE_FAIL_OPEN=true
DATABASE_BACKEND=supabase_rest
DATABASE_TIMEOUT_SECONDS=20
